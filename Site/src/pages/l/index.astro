---
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout title="Shared list · Deadwax Club" description="A shared vinyl record list on Deadwax Club.">
  <header class="site-header">
    <a class="brand-link" href="/" aria-label="Deadwax Club home">
      <span class="logo" aria-hidden="true">
        <img src="/assets/deadwax-logo.svg" alt="" />
      </span>
      <span class="wordmark">Deadwax Club</span>
    </a>
    <a class="header-link" href="/">Get the app</a>
  </header>

  <div class="container list-container">
    <main id="main">
      <div class="state" id="loading">
        <div class="spinner" aria-hidden="true"></div>
        <p>Loading list...</p>
      </div>
    </main>
  </div>

  <footer>
    Want this in your pocket? <a href="/">Get Deadwax Club</a>
  </footer>

  <script is:inline src="/js/config.js"></script>
  <script is:inline type="module" src="/js/list.js"></script>
</SiteLayout>
