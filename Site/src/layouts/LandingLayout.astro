---
import "../landing.css";
import DocumentHead from "../components/DocumentHead.astro";

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogUrl?: string;
}

const { title, description, ogTitle, ogUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <DocumentHead title={title} description={description} ogTitle={ogTitle} ogUrl={ogUrl} />
  <body class="promo-page landing-page">
    <slot />
  </body>
</html>
