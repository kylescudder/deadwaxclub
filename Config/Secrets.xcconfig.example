// Copy this file to Config/Secrets.xcconfig and fill in real values.
// Config/Secrets.xcconfig is gitignored.

// Supabase project URL, e.g. https://abcd1234.supabase.co
// Note: '/' must be escaped as '/$()' in xcconfig.
SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-supabase-anon-key

// PowerSync instance URL from the PowerSync dashboard.
POWERSYNC_URL = https:/$()/your-instance.powersync.journeyapps.com

// Optional. Leave blank to disable Sentry.
SENTRY_DSN =
