// Copy this file to Config/Secrets.xcconfig and fill in real values.
// Config/Secrets.xcconfig is gitignored.

// Supabase API URL.
// Self-hosted: https://api.your-domain.example (the Caddy/Kong entrypoint).
// Supabase Cloud (legacy): https://abcd1234.supabase.co
// Note: '/' must be escaped as '/$()' in xcconfig.
SUPABASE_URL = https:/$()/api.your-domain.example
SUPABASE_ANON_KEY = your-supabase-anon-key

// PowerSync instance URL.
// Self-hosted: https://powersync.your-domain.example (the Caddy entrypoint
// proxying to the journeyapps/powersync-service container).
// PowerSync Cloud (legacy): https://<instance>.powersync.journeyapps.com
POWERSYNC_URL = https:/$()/powersync.your-domain.example

// Optional. Leave blank to disable Sentry.
SENTRY_DSN =
